{
  "name": "nexthono",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:migrate": "wrangler d1 migrations apply nexthono --local",
    "db:migrate:remote": "wrangler d1 migrations apply nexthono --remote",
    "db:seed": "tsx server/api/database/seeds.ts",
    "db:seed:remote": "tsx server/api/database/seeds.ts --remote",
    "db:reset": "wrangler d1 execute nexthono --local --command \"DROP TABLE IF EXISTS users; DROP TABLE IF EXISTS d1_migrations;\" && wrangler d1 migrations apply nexthono --local && tsx server/api/database/seeds.ts",
    "nexthono-module": "tsx .nexthono/create-module.ts",
    "nexthono-field": "tsx .nexthono/add-field.ts"
  },
  "dependencies": {
    "@batistafull/wytext": "latest",
    "@hono/zod-validator": "^0.4.3",
    "@opennextjs/cloudflare": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.7.2",
    "lucide-react": "^0.475.0",
    "next": "^15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "postcss": "^8.5.2",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "wrangler": "^3.99.0"
  }
}
